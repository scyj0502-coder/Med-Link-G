# Copy this file to .local-secrets.txt and fill values locally.
# Never commit .local-secrets.txt.
#
# This file is allowed to look like a human notebook. The setup script accepts
# both formats:
#   SUPABASE_URL=https://xxxx.supabase.co
#   Project URL : https://xxxx.supabase.co

